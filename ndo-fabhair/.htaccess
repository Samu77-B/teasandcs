# Minimal .htaccess - avoid 403 on API (Hostinger)
# Protect config only, allow everything else

Options -Indexes

# Prevent caching of HTML - ensures users get latest version (fixes stuck SW)
<IfModule mod_headers.c>
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    </FilesMatch>
</IfModule>

# Protect sensitive config (DB credentials, env)
<FilesMatch "^(config\.php|config\.local\.php|\.htaccess|\.htpasswd|\.env|\.git)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Security headers (non-blocking)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
