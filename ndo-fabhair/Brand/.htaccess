# ============================================
# BRAND ASSETS DIRECTORY SECURITY .HTACCESS
# Teas & C's PWA Ordering System
# ============================================

# 1. DISABLE DIRECTORY BROWSING
Options -Indexes

# 2. ALLOW IMAGE FILES TO BE SERVED
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|bmp|tiff|PNG)$">
    Order allow,deny
    Allow from all
</FilesMatch>

# 3. BLOCK EXECUTION OF SCRIPTS
<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# 4. BLOCK ACCESS TO SENSITIVE FILES
<FilesMatch "\.(log|sql|bak|backup|old|tmp|temp|swp|swo|htaccess|htpasswd)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# 5. DISABLE SERVER SIGNATURE
ServerSignature Off

# 6. SECURITY HEADERS
<IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=31536000"
    Header always set X-Content-Type-Options "nosniff"
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# 7. PREVENT CROSS-SITE CONTAMINATION
Options -FollowSymLinks
Options +SymLinksIfOwnerMatch

# 8. BLOCK MALICIOUS PATTERNS
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} (\.php|\.php3|\.php4|\.php5|\.phtml|\.pl|\.py|\.jsp|\.asp|\.sh|\.cgi) [NC]
    RewriteRule ^(.*)$ - [F,L]
</IfModule>
